{
	"display_information": {
		"name": "relay",
		"description": "Slack pings without the hassle",
		"background_color": "#2f3033"
	},
	"features": {
		"app_home": {
			"home_tab_enabled": false,
			"messages_tab_enabled": true,
			"messages_tab_read_only_enabled": true
		},
		"bot_user": {
			"display_name": "relay",
			"always_online": true
		},
		"slash_commands": [
			{
				"command": "/relay",
				"description": "Manage Relay groups",
				"usage_hint": "[subcommand]",
				"should_escape": true
			}
		]
	},
	"oauth_config": {
		"scopes": {
			"bot": [
				"channels:read",
				"app_mentions:read",
				"chat:write",
				"commands",
				"im:write",
				"usergroups:read",
				"groups:read",
				"mpim:read",
				"im:read"
			]
		},
		"pkce_enabled": false
	},
	"settings": {
		"event_subscriptions": {
			"bot_events": ["app_mention"]
		},
		"interactivity": {
			"is_enabled": true
		},
		"org_deploy_enabled": false,
		"socket_mode_enabled": true,
		"token_rotation_enabled": false
	}
}
